# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
/PiratePanic/.utmp/
/PiratePanic/[Ll]ibrary/
/PiratePanic/[Tt]emp/
/PiratePanic/[Oo]bj/
/PiratePanic/[Bb]uild/
/PiratePanic/[Bb]uilds/
/PiratePanic/[Ll]ogs/
/PiratePanic/[Uu]ser[Ss]ettings/
/PiratePanic/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/PiratePanic/*.blend1
/PiratePanic/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/PiratePanic/[Mm]emoryCaptures/

# Recordings can get excessive in size
/PiratePanic/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /PiratePanic/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/PiratePanic/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/PiratePanic/*.DotSettings.user

# Visual Studio cache directory
/PiratePanic/.vs/
/PiratePanic/.vscode/

# Gradle cache directory
/PiratePanic/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
/PiratePanic/ServerData
/PiratePanic/[Aa]ssets/StreamingAssets/aa*
/PiratePanic/[Aa]ssets/AddressableAssetsData/link.xml*
/PiratePanic/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /PiratePanic/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/PiratePanic/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/PiratePanic/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/PiratePanic/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/PiratePanic/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/PiratePanic/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/PiratePanic/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
/PiratePanic/[Aa]ssets/[Ss]ceneDependencyCache*


# 屏蔽NakamaServer多余文件
/PiratePanic/nakama-dotnet/
/PiratePanic/NakamaReflector/

/NakamaServer/build/
/NakamaServer/nakama-logs/
/NakamaServer/node_modules/
/NakamaServer/pg-data/
/NakamaServer/.dockerignore
/NakamaServer/package.json
/NakamaServer/package-lock.json
/NakamaServer/tsconfig.json